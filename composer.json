{
    "name": "danial/shwanix-mailer",
    "description": "Laravel mail driver that sends messages through the Shwanix HTTP mail API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Danial",
            "email": "hello@shwanix.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.5",
        "illuminate/mail": "^8.83|^9.0|^10.0",
        "illuminate/support": "^8.83|^9.0|^10.0",
        "symfony/mime": "^5.4|^6.0"
    },
    "autoload": {
        "psr-4": {
            "Danial\\ShwanixMailer\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Danial\\ShwanixMailer\\ShwanixMailerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
